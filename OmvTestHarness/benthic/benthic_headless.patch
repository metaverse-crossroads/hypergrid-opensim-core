+use actix::System;
+use clap::Parser;
+use crossbeam_channel::{unbounded, Sender};
+use log::{error, info, warn, LevelFilter};
+use metaverse_core::initialize::initialize;
+use metaverse_messages::packet::message::{UIMessage, UIResponse};
+use metaverse_messages::ui::login_event::Login;
+use std::net::UdpSocket;
+use std::thread::sleep;
+use std::time::Duration;
+
+#[derive(Parser, Debug)]
+#[command(author, version, about, long_about = None)]
+struct Args {
+    #[arg(short, long, default_value = "Test")]
+    first_name: String,
+
+    #[arg(short, long, default_value = "User")]
+    last_name: String,
+
+    #[arg(short, long, default_value = "password")]
+    password: String,
+
+    #[arg(long, default_value = "http://127.0.0.1:9000")]
+    grid_url: String,
+
+    #[arg(long, default_value_t = 12000)]
+    ui_port: u16,
+
+    #[arg(long, default_value_t = 12001)]
+    core_port: u16,
+}
+
+fn main() {
+    env_logger::builder().filter_level(LevelFilter::Info).init();
+    let args = Args::parse();
+
+    info!("Starting Headless Client for {} {}", args.first_name, args.last_name);
+    info!("UI Port (Listener): {}", args.ui_port);
+    info!("Core Port (Target): {}", args.core_port);
+
+    let (sender, receiver) = unbounded();
+
+    // Start the UI Listener (listens for events FROM Core)
+    let ui_port = args.ui_port;
+    std::thread::spawn(move || {
+        let rt = tokio::runtime::Runtime::new().expect("Failed to create Tokio runtime");
+        rt.block_on(async {
+            listen_for_core_events(ui_port, sender).await;
+        });
+    });
+
+    // Start the Core actor system
+    let core_port_arg = args.core_port;
+    let ui_port_arg = args.ui_port;
+    std::thread::spawn(move || {
+        System::new().block_on(async {
+            // initialize(ui_to_server_socket, server_to_ui_socket)
+            // Core listens on core_port (ui_to_server)
+            // Core sends to ui_port (server_to_ui)
+            match initialize(core_port_arg, ui_port_arg).await {
+                Ok(handle) => {
+                    match handle.await {
+                        Ok(()) => info!("Core Listener exited successfully!"),
+                        Err(e) => error!("Core Listener exited with error {:?}", e),
+                    };
+                }
+                Err(err) => {
+                    error!("Failed to start client core: {:?}", err);
+                }
+            }
+        });
+    });
+
+    // Wait for system to spin up
+    sleep(Duration::from_secs(2));
+
+    // Send Login Packet to Core
+    info!("Sending Login Packet to Core at port {}", args.core_port);
+    let login_msg = UIResponse::Login(Login {
+        first: args.first_name,
+        last: args.last_name,
+        passwd: args.password,
+        start: "home".to_string(),
+        channel: "benthic_headless".to_string(),
+        agree_to_tos: true,
+        read_critical: true,
+        url: args.grid_url,
+    });
+
+    let packet_bytes = login_msg.to_bytes();
+
+    let socket = UdpSocket::bind("0.0.0.0:0").expect("Failed to bind sending socket");
+    match socket.send_to(&packet_bytes, format!("127.0.0.1:{}", args.core_port)) {
+        Ok(_) => info!("Login packet sent to core"),
+        Err(e) => error!("Failed to send login packet: {:?}", e),
+    };
+
+    // Main loop: process events
+    info!("Listening for events...");
+    loop {
+        match receiver.recv() {
+            Ok(event) => {
+                match event {
+                    UIMessage::LoginResponse(response) => {
+                        info!("SUCCESS: Received Login Response: {:?}", response);
+                        info!("Login Successful for {} {}", response.firstname, response.lastname);
+                    }
+                    UIMessage::Error(e) => {
+                        error!("Received Session Error: {:?}", e);
+                    }
+                    other => {
+                        info!("Event: {:?}", other);
+                    }
+                }
+            }
+            Err(e) => {
+                error!("Receiver error: {:?}", e);
+                break;
+            }
+        }
+    }
+}
+
+async fn listen_for_core_events(port: u16, sender: Sender<UIMessage>) {
+    let addr = format!("127.0.0.1:{}", port);
+    let socket = tokio::net::UdpSocket::bind(&addr).await.expect("Failed to bind UDP socket");
+
+    info!("UI listening for core events on UDP: {}", addr);
+    loop {
+        let mut buf = [0u8; 65535]; // Increased buffer size
+        match socket.recv_from(&mut buf).await {
+            Ok((n, _)) => {
+                if let Ok(packet) = UIMessage::from_bytes(&buf[..n]) {
+                    if let Err(e) = sender.send(packet) {
+                        warn!("Failed to send packet to main thread: {:?}", e)
+                    };
+                } else {
+                    warn!("Failed to parse UIMessage");
+                }
+            }
+            Err(e) => {
+                warn!("UI Failed to read buffer {}", e)
+            }
+        }
+    }
+}
